meta {
  name: Flood Zone Check
  type: http
  seq: 5
}

post {
  url: {{aiUwLambdaUrl}}/workflows/flood-zone-check/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_5}}",
    "phase": "PHASE_5"
  }
}
