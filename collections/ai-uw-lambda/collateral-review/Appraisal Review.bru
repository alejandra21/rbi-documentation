meta {
  name: Appraisal Review
  type: http
  seq: 1
}

post {
  url: {{aiUwLambdaUrl}}/workflows/appraisal-review/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_5}}",
    "phase": "PHASE_5"
  }
}
