meta {
  name: TLO vs POS
  type: http
  seq: 1
}

post {
  url: {{aiUwLambdaUrl}}/workflows/tlo-vs-pos/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id}}",
    "phase": "EXTERNAL"
  }
}
