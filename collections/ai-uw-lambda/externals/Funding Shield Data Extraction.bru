meta {
  name: Funding Shield Data Extraction
  type: http
  seq: 3
}

post {
  url: {{aiUwLambdaUrl}}/workflows/funding-shield-data-extraction/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id}}",
    "phase": "EXTERNAL"
  }
}
