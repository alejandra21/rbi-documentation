meta {
  name: LexisNexis POS
  type: http
  seq: 2
}

post {
  url: {{aiUwLambdaUrl}}/workflows/lexisnexis-pos/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id}}",
    "phase": "EXTERNAL"
  }
}
