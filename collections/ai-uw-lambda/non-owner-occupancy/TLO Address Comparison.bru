meta {
  name: TLO Address Comparison
  type: http
  seq: 4
}

post {
  url: {{aiUwLambdaUrl}}/workflows/tlo-address-comparison-entries/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_4}}",
    "phase": "PHASE_4"
  }
}
