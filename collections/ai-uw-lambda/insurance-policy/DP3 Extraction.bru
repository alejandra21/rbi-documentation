meta {
  name: DP3 Extraction
  type: http
  seq: 3
}

post {
  url: {{aiUwLambdaUrl}}/workflows/dp3-extraction/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_9}}",
    "phase": "PHASE_9"
  }
}
