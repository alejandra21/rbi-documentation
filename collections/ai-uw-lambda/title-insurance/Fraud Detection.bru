meta {
  name: Fraud Detection
  type: http
  seq: 5
}

post {
  url: {{aiUwLambdaUrl}}/workflows/fraud-detection/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_7}}",
    "phase": "PHASE_7"
  }
}
