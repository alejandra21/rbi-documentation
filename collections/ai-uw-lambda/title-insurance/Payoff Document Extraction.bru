meta {
  name: Payoff Document Extraction
  type: http
  seq: 6
}

post {
  url: {{aiUwLambdaUrl}}/workflows/payoff-document-extraction/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_7}}",
    "phase": "PHASE_7"
  }
}
