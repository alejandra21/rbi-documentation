meta {
  name: Run All
  type: http
  seq: 1
}

post {
  url: {{aiUwLambdaUrl}}/workflows/phase10-asset-verification/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_10}}",
    "phase": "PHASE_10"
  }
}
