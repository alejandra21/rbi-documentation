meta {
  name: Extraction Bank Statement
  type: http
  seq: 2
}

post {
  url: {{aiUwLambdaUrl}}/workflows/extraction-bank-statement/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_10}}",
    "phase": "PHASE_10"
  }
}
