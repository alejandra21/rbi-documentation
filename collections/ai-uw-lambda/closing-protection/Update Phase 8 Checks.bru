meta {
  name: Update Phase 8 Checks
  type: http
  seq: 5
}

post {
  url: {{aiUwLambdaUrl}}/workflows/update-phase8-checks/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_8}}",
    "phase": "PHASE_8"
  }
}
