meta {
  name: Run All
  type: http
  seq: 1
}

post {
  url: {{aiUwLambdaUrl}}/workflows/phase8-closing-protection/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_8}}",
    "phase": "PHASE_8"
  }
}
