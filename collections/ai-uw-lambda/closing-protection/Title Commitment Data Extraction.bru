meta {
  name: Title Commitment Data Extraction
  type: http
  seq: 4
}

post {
  url: {{aiUwLambdaUrl}}/workflows/title-commitment-data-extraction/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_8}}",
    "phase": "PHASE_8"
  }
}
