meta {
  name: Investor Classification
  type: http
  seq: 4
}

post {
  url: {{aiUwLambdaUrl}}/workflows/investor-classification/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_2}}",
    "phase": "PHASE_2"
  }
}
