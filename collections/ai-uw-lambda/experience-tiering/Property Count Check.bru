meta {
  name: Property Count Check
  type: http
  seq: 2
}

post {
  url: {{aiUwLambdaUrl}}/workflows/property-count-check/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_2}}",
    "phase": "PHASE_2"
  }
}
