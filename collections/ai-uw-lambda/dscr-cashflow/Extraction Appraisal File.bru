meta {
  name: Extraction Appraisal File
  type: http
  seq: 3
}

post {
  url: {{aiUwLambdaUrl}}/workflows/extraction-load-appraisal-file/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_6}}",
    "phase": "PHASE_6"
  }
}
