meta {
  name: Owners ID Analyzer
  type: http
  seq: 6
}

post {
  url: {{aiUwLambdaUrl}}/workflows/owners-id-analyzer/run
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_1}}",
    "phase": "PHASE_1"
  }
}
