meta {
  name: Validations Entity
  type: http
  seq: 2
}

post {
  url: {{aiUwLambdaUrl}}/workflows/validations-entity/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_1}}",
    "phase": "PHASE_1"
  }
}
