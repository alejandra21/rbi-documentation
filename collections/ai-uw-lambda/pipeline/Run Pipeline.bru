meta {
  name: Run Pipeline
  type: http
  seq: 1
}

post {
  url: {{aiUwLambdaUrl}}/pipeline/run
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "loan_id": {{loan_id}},
    "workflow_id": "{{workflow_id}}",
    "workflow_run_id": "{{workflow_run_id_phase_1}}"
  }
}
